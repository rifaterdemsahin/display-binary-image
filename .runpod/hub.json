{
    "name": "Uncensored SDXL Serverless Worker",
    "description": "A high-performance serverless worker for SDXL running unfiltered custom models.",
    "version": "1.0.0",
    "category": "Serverless",
    "container_image": "rifaterdemsahin/display-binary-image:latest",
    "environment_variables": [
        {
            "key": "SAFETY_CHECKER",
            "value": "false",
            "description": "Disables the default NSFW block",
            "required": true
        },
        {
            "key": "HF_HOME",
            "value": "/workspace/cache/huggingface",
            "description": "Persistent caching path",
            "required": true
        }
    ],
    "volume_mount_path": "/workspace",
    "default_gpu": "NVIDIA GeForce RTX 4090",
    "min_disk": 10
}
